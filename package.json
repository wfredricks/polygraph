{
  "name": "polygraph-db",
  "version": "0.1.0",
  "description": "An embeddable graph database you can own, audit, and authorize. Labeled property graph engine in pure TypeScript.",
  "author": "William Fredricks",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/wfredricks/polygraph.git"
  },
  "homepage": "https://github.com/wfredricks/polygraph#readme",
  "bugs": {
    "url": "https://github.com/wfredricks/polygraph/issues"
  },
  "keywords": [
    "graph",
    "graph-database",
    "labeled-property-graph",
    "embedded",
    "embeddable",
    "knowledge-graph",
    "traversal",
    "typescript",
    "fedramp",
    "nist-800-53",
    "government",
    "digital-twin",
    "audit"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "ROADMAP.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:security": "vitest run src/__tests__/security/",
    "test:bench": "vitest run src/__tests__/benchmarks/",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "msgpackr": "^2.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
